# KetdikGo bot — muhit o'zgaruvchilari
# Nusxa oling:  cp .env.example .env   (va qiymatlarni to'ldiring)

# @BotFather'dan olingan token (MAJBURIY). Bo'lmasa bot ishga tushmaydi.
# Eslatma: Render'da eski `TELEGRAM_BOT_TOKEN` bo'lsa, bot uni ham o'qiydi
# (BOT_TOKEN birinchi tekshiriladi). Qiymat @ketdikgobot tokeni bo'lsin.
BOT_TOKEN=

# --- Quyidagilar IXTIYORIY: berilmasa config.js'dagi standart qiymat ishlatiladi ---

# KetdikGo ilova havolasi (Play Store). Hali nashr qilinmagani uchun standart: https://ketdikgo.uz
# Play Store'da chiqqach shu yerga to'liq havola qo'ying, masalan:
# https://play.google.com/store/apps/details?id=uz.ketdik.mijoz
PLAY_STORE_URL=

# App Store havolasi (iOS) — ixtiyoriy
APP_STORE_URL=

# Dispetcher telefon raqami (standart: 1226)
DISPATCHER_PHONE=

# Sayt va Maxfiylik havolalari (ixtiyoriy — standart: https://ketdikgo.uz[/privacy])
SITE_URL=
PRIVACY_URL=
